rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isValidFlower(data) {
      return data.keys().hasAll(['planterName', 'message', 'color', 'x', 'y', 'createdAt']) &&
             data.planterName is string && data.planterName.size() <= 50 &&
             data.message is string && data.message.size() <= 200 &&
             data.color is string && data.color.size() <= 20 &&
             data.x is number && data.x >= 0 && data.x <= 100 &&
             data.y is number && data.y >= 0 && data.y <= 100 &&
             (data.get('rarity', 'common') in ['common', 'rare', 'legendary']) &&
             (data.get('careCount', 0) is int) &&
             data.createdAt == request.time;
    }

    match /flowers/{flowerId} {
      allow read: if true; 
      allow create: if isValidFlower(request.resource.data);
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['careCount']) &&
        request.resource.data.careCount == resource.data.get('careCount', 0) + 1
      );
      allow delete: if false; 
    }
  }
}
